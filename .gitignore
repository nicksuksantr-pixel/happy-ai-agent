# v2.7.0: bundled embedded Python — ~50 MB unpacked, re-stageable
# via `python tools/stage_embedded_python.py`. Don't commit; rebuild
# on each dev box. CI clones can also re-stage (the script is idempotent).
vendor/

# Installer build outputs — .iss script + assets ใน installer/ ส่งขึ้น git ได้
# แต่ compiled .exe ใหญ่เกินไป ไม่ commit
installer/output/

# Release archive — .exe/.zip ใหญ่ ไม่ commit (แต่ release-notes.md เก็บได้)
releases/*/*.exe
releases/*/*.zip

# Claude Code worktree — internal use, อย่า commit
.claude/worktrees/

# Personal files ที่หลุดเข้าโปรเจกต์ — gitignored explicit (ไม่ใช่ HAPPY source)
Nick_Creative_Portfolio.docx
ระบบดาวเทียม.html

# Backups
*.bak
*.bak[0-9]*

# Test screenshots — regeneratable by running ui_verify.py / bug5_*.py
ui_screenshots/

# Local auth (defense in depth — real file lives in ~/.happy/)
.happy/

